# Copy this file to local.properties and fill in your values
# local.properties is in .gitignore and must NEVER be committed

# Android SDK path
sdk.dir=/Users/yourname/Library/Android/sdk

# Keystore signing credentials
KEY_STORE_FILE=android.keystore
KEY_STORE_PASSWORD=your_keystore_password_here
KEY_ALIAS=android
KEY_PASSWORD=your_key_password_here
